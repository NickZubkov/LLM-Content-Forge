# Root .gitignore — server (.NET) and repo-wide.
# The Unity project keeps its own .gitignore under unity/.

# .NET build output
[Bb]in/
[Oo]bj/
[Oo]ut/
*.user
*.suo

# Rider / Visual Studio
.idea/
.vs/

# Internal, non-committed docs and instructions
/Docs/

# Transient Unity leftovers at repo root (pre-monorepo-move; regenerated under unity/)
/Library/
/Temp/

# OS
.DS_Store
Thumbs.db
